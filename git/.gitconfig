[user]
	name = Lukas Grassauer
	email = lukas@grassauer.eu
[push]
	default = simple
[alias]
	fresh = "!git pull --stat --ff-only || git pull --stat --rebase"
	last = log -1 HEAD
    	co = checkout
	st = status
[merge]
	tool = meld
[core]
	editor = "vim -c 'norm! gg'"
	excludesfile = /home/lukas/.gitignore_global
	pager = diff-so-fancy | less --tabs=1,5 -R -F -+X
[rebase]
	autoStash = true
[pager]
	diff
