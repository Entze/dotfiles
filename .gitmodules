[submodule "zplugin"]
	path = zsh/.zplugin/bin
	url = https://github.com/zdharma/zplugin
	shallow = true
[submodule "nord-dircolors"]
	path = zsh/.nord-dircolors
	url = https://github.com/arcticicestudio/nord-dircolors.git
	shallow = true
[submodule "nord-gnome-terminal"]
	path = nord-gnome-terminal
	url = https://github.com/arcticicestudio/nord-gnome-terminal.git
	shallow = true
